# =============================================================================
# RaidFlow – Umgebungsvariablen (Kopie als .env.local und Werte eintragen)
# =============================================================================
# Keine echten Secrets hier eintragen! Nur Platzhalter/Dokumentation.
# Auf Vercel: Settings → Environment Variables mit diesen Keys befüllen.
# NEXTAUTH_URL auf Vercel auf die Production-URL setzen (z.B. https://<projekt>.vercel.app).

# -----------------------------------------------------------------------------
# NextAuth.js & Discord OAuth (Login)
# -----------------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=<generierter Secret, z.B. openssl rand -base64 32>

DISCORD_CLIENT_ID=<Discord Application Client ID>
DISCORD_CLIENT_SECRET=<Discord Application Client Secret>

# -----------------------------------------------------------------------------
# Discord-Bot (Slash-Commands, Rollen, Threads)
# -----------------------------------------------------------------------------
DISCORD_BOT_TOKEN=<Discord Bot Token>
DISCORD_BOT_CLIENT_ID=<Bot Application ID, oft gleich wie DISCORD_CLIENT_ID>
BOT_SETUP_SECRET=<Shared Secret für Bot ↔ Webapp API>
WEBAPP_URL=http://localhost:3000
WEBAPP_OWNER_DISCORD_ID=<Discord User ID des App-Owners>

# -----------------------------------------------------------------------------
# Datenbank (Supabase PostgreSQL)
# -----------------------------------------------------------------------------
# Prisma: Connection Pool (Transaction Mode, z.B. Supabase Pooler Port 6543)
DATABASE_URL="postgresql://...?pgbouncer=true"

# Prisma Migrationen: Direct URL (Session Mode, z.B. Port 5432)
DIRECT_URL="postgresql://..."

# -----------------------------------------------------------------------------
# Optional: Supabase Client (falls Frontend/SDK genutzt wird)
# -----------------------------------------------------------------------------
# Preview (dieses Cursor-Projekt): supabase-raidflow-preview
# NEXT_PUBLIC_SUPABASE_URL=https://obewcnxrkatwcsjyqhdd.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon key aus Supabase Dashboard>
# SUPABASE_SERVICE_ROLE_KEY=<service role, nur Server-side>
