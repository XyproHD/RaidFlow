// RaidFlow – Prisma-Schema (Referenz: db_schema.md)
// Tabellen mit Präfix rf_ in PostgreSQL (Supabase)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// -----------------------------------------------------------------------------
// User & Guild
// -----------------------------------------------------------------------------

model RfUser {
  id              String    @id @default(uuid())
  discordId       String    @unique @map("discord_id")
  themePreference String?   @map("theme_preference") // "light" | "dark" – Anzeige-Modus, wird auch per Cookie gespeichert
  lastActiveAt    DateTime? @map("last_active_at")  // Letzte Aktivität in RaidFlow
  status          String   @default("aktiv")       // aktiv | inaktiv | deaktiviert
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  userGuilds       RfUserGuild[]
  guildMembers     RfGuildMember[]
  characters       RfCharacter[]
  raidTimePrefs    RfRaidTimePreference[]
  raidSignups      RfRaidSignup[]
  raidCompletions  RfRaidCompletion[]
  loots            RfLoot[]
  auditLogs        RfAuditLog[]

  @@map("rf_user")
}

model RfGuild {
  id                          String   @id @default(uuid())
  discordGuildId              String   @unique @map("discord_guild_id")
  name                        String
  botInviteStatus             String?  @map("bot_invite_status")
  discordRoleGuildmasterId    String?  @map("discord_role_guildmaster_id")
  discordRoleRaidleaderId     String?  @map("discord_role_raidleader_id")
  discordRoleRaiderId         String?  @map("discord_role_raider_id")
  createdAt                   DateTime @default(now()) @map("created_at")
  updatedAt                   DateTime @updatedAt @map("updated_at")

  userGuilds            RfUserGuild[]
  raidGroups            RfRaidGroup[]
  guildMembers          RfGuildMember[]
  characters            RfCharacter[]
  raids                 RfRaid[]
  guildAllowedChannels  RfGuildAllowedChannel[]
  loots                 RfLoot[]
  auditLogs             RfAuditLog[]

  @@map("rf_guild")
}

model RfUserGuild {
  userId       String    @map("user_id")
  guildId     String    @map("guild_id")
  role        String
  joinedAt    DateTime  @default(now()) @map("joined_at")
  lastActiveAt DateTime? @map("last_active_at") // Letzte Aktivität in dieser Gilde
  status      String    @default("aktiv")       // aktiv | inaktiv | deaktiviert

  user   RfUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  guild  RfGuild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@id([userId, guildId])
  @@map("rf_user_guild")
}

model RfRaidGroup {
  id             String   @id @default(uuid())
  guildId        String   @map("guild_id")
  name           String
  discordRoleId  String?  @map("discord_role_id")
  sortOrder      Int      @default(0) @map("sort_order")

  guild                 RfGuild                      @relation(fields: [guildId], references: [id], onDelete: Cascade)
  memberRaidGroups      RfGuildMemberRaidGroup[]
  raids                 RfRaid[]                     @relation("RaidGroupRestriction")
  raidGroupCharacters   RfRaidGroupCharacter[]

  @@map("rf_raid_group")
}

model RfRaidGroupCharacter {
  id          String   @id @default(uuid())
  raidGroupId String   @map("raid_group_id")
  characterId String   @map("character_id")
  allowed     Boolean  @default(true)

  raidGroup RfRaidGroup  @relation(fields: [raidGroupId], references: [id], onDelete: Cascade)
  character RfCharacter  @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([raidGroupId, characterId])
  @@map("rf_raid_group_character")
}

model RfGuildMemberRaidGroup {
  guildMemberId String @map("guild_member_id")
  raidGroupId   String @map("raid_group_id")

  guildMember RfGuildMember @relation(fields: [guildMemberId], references: [id], onDelete: Cascade)
  raidGroup   RfRaidGroup    @relation(fields: [raidGroupId], references: [id], onDelete: Cascade)

  @@id([guildMemberId, raidGroupId])
  @@map("rf_guild_member_raid_group")
}

model RfGuildMember {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  guildId      String    @map("guild_id")
  joinedAt     DateTime  @default(now()) @map("joined_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user             RfUser                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  guild            RfGuild                   @relation(fields: [guildId], references: [id], onDelete: Cascade)
  memberRaidGroups RfGuildMemberRaidGroup[]

  @@unique([userId, guildId])
  @@map("rf_guild_member")
}

// -----------------------------------------------------------------------------
// Character, RaidTimePreference, Dungeon
// -----------------------------------------------------------------------------

model RfCharacter {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  guildId   String?  @map("guild_id")
  name      String
  mainSpec  String   @map("main_spec")
  offSpec   String?  @map("off_spec")
  isMain    Boolean  @default(false) @map("is_main")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user                RfUser                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  guild                RfGuild?                @relation(fields: [guildId], references: [id], onDelete: SetNull)
  raidSignups          RfRaidSignup[]
  raidCompletions      RfRaidCompletion[]
  loots                RfLoot[]
  raidGroupCharacters  RfRaidGroupCharacter[]
  battlenetProfile     RfBattlenetCharacterProfile?

  @@map("rf_character")
}

model RfRaidTimePreference {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  weekday    String
  timeSlot   String   @map("time_slot")
  preference String
  weekFocus  String?  @map("week_focus")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user RfUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("rf_raid_time_preference")
}

model RfDungeon {
  id             String   @id @default(uuid())
  name           String   // Fallback/Default-Name (z. B. en)
  expansion      String
  instanceType   String   @map("instance_type")   // "dungeon" | "raid"
  maxPlayers     Int      @map("max_players")    // 5 = Dungeon, 10/25 = Schlachtzug
  resetType      String?  @map("reset_type")     // "weekly" | "daily" | "per_run"
  resetWeekday   Int?     @map("reset_weekday")  // 0=Sonntag .. 6=Samstag (EU weekly: 3=Mittwoch)
  resetTimeUtc   String?  @map("reset_time_utc") // HH:MM UTC (z. B. "04:00")
  addonNames     Json?    @map("addon_names")    // ["AtlasLoot","InstanceID","Atlas"]

  names  RfDungeonName[]
  raids  RfRaid[]
  loots  RfLoot[]

  @@map("rf_dungeon")
}

model RfDungeonName {
  dungeonId String @map("dungeon_id")
  locale    String // de, en, fr, …
  name      String

  dungeon RfDungeon @relation(fields: [dungeonId], references: [id], onDelete: Cascade)

  @@id([dungeonId, locale])
  @@map("rf_dungeon_name")
}

// -----------------------------------------------------------------------------
// Raid, Signup, Completion
// -----------------------------------------------------------------------------

model RfRaid {
  id                      String    @id @default(uuid())
  guildId                 String    @map("guild_id")
  dungeonId               String    @map("dungeon_id")
  name                    String
  raidLeaderId            String?   @map("raid_leader_id")
  lootmasterId            String?   @map("lootmaster_id")
  minTanks                Int       @map("min_tanks")
  minMelee                Int       @map("min_melee")
  minRange                Int       @map("min_range")
  minHealers              Int       @map("min_healers")
  minSpecs                Json?     @map("min_specs")
  raidGroupRestrictionId  String?   @map("raid_group_restriction_id")
  note                    String?   @db.Text
  maxPlayers              Int       @map("max_players")
  scheduledAt             DateTime  @map("scheduled_at")
  signupUntil             DateTime  @map("signup_until")
  signupVisibility        String    @map("signup_visibility")
  status                  String
  discordThreadId         String?   @map("discord_thread_id")
  discordChannelId       String?   @map("discord_channel_id")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  guild         RfGuild   @relation(fields: [guildId], references: [id], onDelete: Cascade)
  dungeon       RfDungeon @relation(fields: [dungeonId], references: [id], onDelete: Restrict)
  raidGroupRestriction RfRaidGroup? @relation("RaidGroupRestriction", fields: [raidGroupRestrictionId], references: [id], onDelete: SetNull)
  signups       RfRaidSignup[]
  completions   RfRaidCompletion[]
  auditLogs     RfAuditLog[]

  @@map("rf_raid")
}

model RfRaidSignup {
  id            String    @id @default(uuid())
  raidId        String    @map("raid_id")
  userId        String    @map("user_id")
  characterId   String?   @map("character_id")
  type          String
  allowReserve  Boolean   @default(false) @map("allow_reserve")
  note          String?   @db.Text
  setConfirmed  Boolean   @default(false) @map("set_confirmed")
  signedAt      DateTime  @default(now()) @map("signed_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  raid      RfRaid     @relation(fields: [raidId], references: [id], onDelete: Cascade)
  user      RfUser     @relation(fields: [userId], references: [id], onDelete: Cascade)
  character RfCharacter? @relation(fields: [characterId], references: [id], onDelete: SetNull)

  @@map("rf_raid_signup")
}

model RfRaidCompletion {
  id                   String   @id @default(uuid())
  raidId               String   @map("raid_id")
  userId               String   @map("user_id")
  characterId          String?  @map("character_id")
  participationCounter Decimal  @map("participation_counter") @db.Decimal(3, 2)
  createdAt            DateTime @default(now()) @map("created_at")

  raid      RfRaid      @relation(fields: [raidId], references: [id], onDelete: Cascade)
  user      RfUser      @relation(fields: [userId], references: [id], onDelete: Cascade)
  character RfCharacter? @relation(fields: [characterId], references: [id], onDelete: SetNull)

  @@map("rf_raid_completion")
}

model RfLoot {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  guildId     String   @map("guild_id")
  dungeonId   String   @map("dungeon_id")
  characterId String?  @map("character_id")
  itemRef     String   @map("item_ref")
  receivedAt  DateTime @map("received_at")

  user      RfUser     @relation(fields: [userId], references: [id], onDelete: Cascade)
  guild     RfGuild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  dungeon   RfDungeon  @relation(fields: [dungeonId], references: [id], onDelete: Restrict)
  character RfCharacter? @relation(fields: [characterId], references: [id], onDelete: SetNull)

  @@map("rf_loot")
}

model RfGuildAllowedChannel {
  id                String    @id @default(uuid())
  guildId           String    @map("guild_id")
  discordChannelId  String    @map("discord_channel_id")
  name              String?
  lastValidatedAt   DateTime? @map("last_validated_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  guild RfGuild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@map("rf_guild_allowed_channel")
}

model RfAppAdmin {
  id                 String   @id @default(uuid())
  discordUserId      String   @unique @map("discord_user_id")
  addedByDiscordId   String?  @map("added_by_discord_id")
  createdAt          DateTime @default(now()) @map("created_at")

  @@map("rf_app_admin")
}

model RfAppConfig {
  key   String @id
  value String @db.Text

  @@map("rf_app_config")
}

model RfBattlenetApiConfig {
  id                  String   @id @default(uuid())
  region              String   @unique
  clientId            String   @map("client_id")
  clientSecret        String   @map("client_secret")
  locale              String   @default("de_DE")
  namespaceProfile    String   @map("namespace_profile")
  namespaceDynamic    String   @map("namespace_dynamic")
  oauthTokenUrl       String   @map("oauth_token_url")
  apiBaseUrl          String   @map("api_base_url")
  searchCharacterPath String   @default("/data/wow/search/character") @map("search_character_path")
  searchGuildPath     String   @default("/data/wow/search/guild") @map("search_guild_path")
  profileCharacterPath String  @default("/profile/wow/character") @map("profile_character_path")
  profileGuildPath     String  @default("/data/wow/guild") @map("profile_guild_path")
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  characterProfiles   RfBattlenetCharacterProfile[]

  @@map("rf_battlenet_api_config")
}

model RfBattlenetCharacterProfile {
  id                   String    @id @default(uuid())
  characterId          String    @unique @map("character_id")
  battlenetConfigId    String?   @map("battlenet_config_id")
  region               String
  wowVersion           String?   @map("wow_version")
  realmSlug            String    @map("realm_slug")
  realmName            String?   @map("realm_name")
  characterNameLower   String    @map("character_name_lower")
  battlenetCharacterId BigInt?   @map("battlenet_character_id")
  level                Int?
  raceName             String?   @map("race_name")
  className            String?   @map("class_name")
  activeSpecName       String?   @map("active_spec_name")
  guildName            String?   @map("guild_name")
  faction              String?
  profileUrl           String?   @map("profile_url")
  rawProfile           Json?     @map("raw_profile")
  lastSyncedAt         DateTime  @default(now()) @map("last_synced_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  character       RfCharacter            @relation(fields: [characterId], references: [id], onDelete: Cascade)
  battlenetConfig RfBattlenetApiConfig?  @relation(fields: [battlenetConfigId], references: [id], onDelete: SetNull)

  @@unique([region, realmSlug, characterNameLower])
  @@map("rf_battlenet_character_profile")
}

model RfBattlenetRealm {
  id         String   @id @default(uuid())
  realmId    BigInt   @map("realm_id")
  name       Json
  slug       String
  region     String
  namespace  String
  version    String
  type       String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([region, namespace, realmId])
  @@unique([region, namespace, slug])
  @@map("rf_battlenet_realm")
}

model RfAuditLog {
  id                String   @id @default(uuid())
  entityType        String   @map("entity_type")
  entityId          String   @map("entity_id")
  action            String
  changedByUserId   String   @map("changed_by_user_id")
  fieldName         String?  @map("field_name")
  oldValue          String?  @map("old_value") @db.Text
  newValue          String?  @map("new_value") @db.Text
  guildId           String?  @map("guild_id")
  raidId            String?  @map("raid_id")
  createdAt         DateTime @default(now()) @map("created_at")

  user  RfUser  @relation(fields: [changedByUserId], references: [id], onDelete: Cascade)
  guild RfGuild? @relation(fields: [guildId], references: [id], onDelete: SetNull)
  raid  RfRaid?  @relation(fields: [raidId], references: [id], onDelete: SetNull)

  @@map("rf_audit_log")
}